# Firebase Authentication — get these from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Backend API URL (leave empty for local development — auto-detects localhost:8000)
# NEXT_PUBLIC_API_URL=https://your-backend.run.app

# WebSocket URL (auto-derived from API URL if not set)
# NEXT_PUBLIC_WS_URL=wss://your-backend.run.app
